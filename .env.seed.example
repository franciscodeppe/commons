# Copy to .env.seed.local (gitignored) and fill in your DEV project's values.
# Get these from the dev Supabase project → Settings → API.
# NEVER use your production project here.

SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_DEV_SERVICE_ROLE_KEY

# Optional overrides:
# SEED_USERS=200
# SEED_GROUPS=40
# SEED_PASSWORD=commons-dev
# SEED_RESET=1        # wipe previously-seeded users before re-seeding
